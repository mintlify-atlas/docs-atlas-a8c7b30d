  "keyFeatures": [
    "Custom emote support with emote sets and emote management",
    "Modular add-on system with full lifecycle management (load/unload/enable/disable)",
    "Deep Twitch UI customization via CSS tweaks and component overrides",
    "Robust settings system with profiles, contexts, and providers",
    "Real-time event system with typed namespaced events",
    "Chat enhancement with custom tokenizers, badges, and link providers",
    "Internationalization (i18n) and translation support",
    "Experiments and A/B testing framework",
    "Socket-based real-time communication with FrankerFaceZ servers",
    "Browser extension and userscript deployment modes"
  ],
  "publicApiSurface": [
    "FrankerFaceZ (main class, window.ffz)",
    "Module (base class for all modules and add-ons)",
    "Addon (subclass of Module for add-on root modules)",
    "Addon.register(id, info) — registers an add-on with FFZ",
    "Module.inject(name, module) — injects a module dependency",
    "Module.register(name, module) — registers a child module",
    "Module.resolve(name) — resolves a module by path",
    "Module.enable() / Module.disable()",
    "Module.load() / Module.unload()",
    "SettingsManager.add(key, definition) — registers a setting",
    "SettingsManager.get(key) — retrieves a setting value",
    "SettingsManager.set(key, value) — sets a setting value",
    "EventEmitter.on(event, fn) / EventEmitter.off(event, fn)",
    "EventEmitter.emit(event, ...args)",
    "FrankerFaceZ.utilities (addon, blobs, color, dom, events, filtering, graphql, logging, module, object, time, tooltip, i18n)"
  ]
